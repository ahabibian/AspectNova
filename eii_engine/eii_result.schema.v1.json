{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eii-result.schema.v1",
  "title": "EII Result Output Schema (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "generated_at",
    "source_scan",
    "engine_version",
    "aggregates",
    "energy_impact",
    "eii_score",
    "optimization_potential",
    "assumptions"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "eii-result" },
    "schema_version": { "type": "string", "const": "v1" },
    "generated_at": { "type": "string", "format": "date-time" },

    "source_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_version", "generated_at", "root"],
      "properties": {
        "schema_id": { "type": "string", "const": "scan-result" },
        "schema_version": { "type": "string", "const": "v1" },
        "generated_at": { "type": "string", "format": "date-time" },
        "root": { "type": "string", "minLength": 1 }
      }
    },

    "engine_version": { "type": "string", "minLength": 1 },

    "aggregates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_count", "total_size_bytes", "total_size_gb", "by_extension_gb"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "total_size_bytes": { "type": "integer", "minimum": 0 },
        "total_size_gb": { "type": "number", "minimum": 0 },
        "by_extension_gb": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    },

    "energy_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monthly", "annual"],
      "properties": {
        "monthly": {
          "type": "object",
          "additionalProperties": false,
          "required": ["energy_kwh", "co2_kg", "cost_sek"],
          "properties": {
            "energy_kwh": { "type": "number", "minimum": 0 },
            "co2_kg": { "type": "number", "minimum": 0 },
            "cost_sek": { "type": "number", "minimum": 0 }
          }
        },
        "annual": {
          "type": "object",
          "additionalProperties": false,
          "required": ["energy_kwh", "co2_kg", "cost_sek"],
          "properties": {
            "energy_kwh": { "type": "number", "minimum": 0 },
            "co2_kg": { "type": "number", "minimum": 0 },
            "cost_sek": { "type": "number", "minimum": 0 }
          }
        }
      }
    },

    "eii_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "grade", "explanation"],
      "properties": {
        "value": { "type": "integer", "minimum": 0, "maximum": 100 },
        "grade": { "type": "string", "enum": ["A", "B", "C", "D", "E"] },
        "explanation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary_drivers"],
          "properties": {
            "primary_drivers": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": { "type": "string", "minLength": 3 }
            }
          }
        }
      }
    },

    "optimization_potential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reclaimable_storage_gb",
        "energy_saving_kwh_year",
        "co2_reduction_kg_year",
        "cost_saving_sek_year"
      ],
      "properties": {
        "reclaimable_storage_gb": { "type": "number", "minimum": 0 },
        "energy_saving_kwh_year": { "type": "number", "minimum": 0 },
        "co2_reduction_kg_year": { "type": "number", "minimum": 0 },
        "cost_saving_sek_year": { "type": "number", "minimum": 0 }
      }
    },

    "assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "region",
        "energy_per_tb_month_kwh",
        "co2_g_per_kwh",
        "electricity_price_sek_per_kwh",
        "reclaimable_fraction_default",
        "data_source"
      ],
      "properties": {
        "region": { "type": "string", "minLength": 2 },
        "energy_per_tb_month_kwh": { "type": "number", "exclusiveMinimum": 0 },
        "co2_g_per_kwh": { "type": "number", "minimum": 0 },
        "electricity_price_sek_per_kwh": { "type": "number", "minimum": 0 },
        "reclaimable_fraction_default": { "type": "number", "minimum": 0, "maximum": 1 },
        "data_source": { "type": "string", "enum": ["static", "user", "provider"] }
      }
    }
  }
}
