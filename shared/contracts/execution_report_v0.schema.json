{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aspectnova.dev/schemas/execution-report/v0.json",
  "title": "Execution Report (v0)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "generated_at",
    "runner",
    "decision_snapshot",
    "payload_snapshot",
    "summary",
    "results"
  ],
  "properties": {
    "schema_id": { "const": "execution-report" },
    "schema_version": { "const": "v0" },
    "generated_at": { "type": "string", "format": "date-time" },

    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "safe_mode", "execute_requested", "confirm_received"],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "safe_mode": { "type": "boolean" },
        "execute_requested": { "type": "boolean" },
        "confirm_received": { "type": "boolean" }
      }
    },

    "decision_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "priority", "risk_bucket", "confidence", "reasons"],
      "properties": {
        "policy_id": { "type": "string", "minLength": 3 },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "risk_bucket": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },

    "payload_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_version", "kpis"],
      "properties": {
        "schema_id": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "kpis": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "files_scanned": { "type": ["integer", "null"], "minimum": 0 },
            "total_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
            "energy_kwh_month": { "type": ["number", "null"], "minimum": 0 },
            "energy_kwh_year": { "type": ["number", "null"], "minimum": 0 },
            "co2_kg_month": { "type": ["number", "null"], "minimum": 0 },
            "co2_kg_year": { "type": ["number", "null"], "minimum": 0 },
            "cost_sek_month": { "type": ["number", "null"], "minimum": 0 },
            "cost_sek_year": { "type": ["number", "null"], "minimum": 0 },
            "eii_score_value": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "eii_grade": { "type": ["string", "null"] }
          }
        }
      }
    },

    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "ok", "skipped", "blocked", "failed", "status"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "ok": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["ok", "failed"] }
      }
    },

    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/resultItem" }
    }
  },

  "$defs": {
    "resultItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "status",
        "message",
        "started_at",
        "finished_at",
        "details"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "type": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },

        "status": {
          "type": "string",
          "enum": ["ok", "skipped", "blocked", "failed"]
        },

        "message": { "type": "string" },

        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },

        "details": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "supported_types": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
