{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aspectnova.local/schemas/actions/cleanup.candidates.v1.inputs.json",
  "title": "cleanup.candidates.v1 inputs",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope", "ruleset_id", "limits", "hashing"],
  "properties": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roots", "include_globs", "exclude_globs"],
      "properties": {
        "roots": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "description": "Root paths to scan (absolute or workspace-relative, depending on runner config)."
        },
        "include_globs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "description": "Glob patterns to include (e.g., **/*)."
        },
        "exclude_globs": {
          "type": "array",
          "minItems": 0,
          "maxItems": 256,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "description": "Glob patterns to exclude (e.g., **/node_modules/**)."
        },
        "follow_symlinks": {
          "type": "boolean",
          "default": false,
          "description": "If true, follow symlinks (not recommended for safety)."
        }
      }
    },

    "ruleset_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$",
      "description": "Versioned ruleset identifier, e.g., rules.cleanup.v1"
    },

    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_files", "max_depth", "time_budget_sec"],
      "properties": {
        "max_files": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200000,
          "description": "Stop scanning after this many filesystem entries."
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum directory depth from each root."
        },
        "time_budget_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300,
          "description": "Wall-clock budget for scanning + scoring."
        }
      }
    },

    "hashing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "If true, compute file hashes (optional; expensive)."
        },
        "algorithm": {
          "type": "string",
          "enum": ["sha256", "blake3"],
          "default": "sha256",
          "description": "Hash algorithm if hashing.enabled is true."
        },
        "max_file_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "default": 268435456,
          "description": "Do not hash files larger than this size (bytes). Default 256MB."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": false } },
            "required": ["enabled"]
          },
          "then": {
            "not": {
              "required": ["algorithm", "max_file_bytes"]
            }
          }
        }
      ]
    },

    "signals": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional knobs for which signals are enabled (executor may ignore unknowns).",
      "properties": {
        "stale_access_days": {
          "type": "integer",
          "minimum": 0,
          "maximum": 36500,
          "default": 365,
          "description": "Days since last access to be considered stale."
        },
        "stale_modified_days": {
          "type": "integer",
          "minimum": 0,
          "maximum": 36500,
          "default": 730,
          "description": "Days since last modified to be considered stale."
        },
        "min_candidate_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9223372036854775807,
          "default": 1048576,
          "description": "Minimum size for a file to be considered a candidate (bytes). Default 1MB."
        },
        "allow_temp_paths": {
          "type": "boolean",
          "default": true,
          "description": "If true, include temp/cache locations in candidate suggestions."
        }
      }
    }
  }
}
