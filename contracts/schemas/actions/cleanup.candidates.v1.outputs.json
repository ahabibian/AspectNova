{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aspectnova.local/schemas/actions/cleanup.candidates.v1.outputs.json",
  "title": "cleanup.candidates.v1 outputs",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "candidates", "warnings", "provenance"],
  "properties": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scanned_entries",
        "scanned_files",
        "scanned_dirs",
        "candidates_count",
        "candidate_bytes_total",
        "time_elapsed_ms"
      ],
      "properties": {
        "scanned_entries": { "type": "integer", "minimum": 0 },
        "scanned_files": { "type": "integer", "minimum": 0 },
        "scanned_dirs": { "type": "integer", "minimum": 0 },
        "candidates_count": { "type": "integer", "minimum": 0 },
        "candidate_bytes_total": { "type": "integer", "minimum": 0 },
        "time_elapsed_ms": { "type": "integer", "minimum": 0 },

        "limits_reached": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_files", "max_depth", "time_budget"],
          "properties": {
            "max_files": { "type": "boolean" },
            "max_depth": { "type": "boolean" },
            "time_budget": { "type": "boolean" }
          },
          "default": { "max_files": false, "max_depth": false, "time_budget": false }
        }
      }
    },

    "candidates": {
      "type": "array",
      "maxItems": 200000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "kind",
          "bytes",
          "signals",
          "reasons",
          "risk",
          "confidence",
          "proposed_next"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]*$",
            "description": "Stable candidate id within this run (may be derived from path+metadata hash)."
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "kind": {
            "type": "string",
            "enum": ["file", "dir"]
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },

          "signals": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {
              "type": "string",
              "minLength": 2,
              "maxLength": 64,
              "pattern": "^[a-z0-9_.:->=]+$"
            },
            "description": "Machine-friendly tags, e.g. stale.last_accessed>365d"
          },

          "reasons": {
            "type": "array",
            "minItems": 1,
            "maxItems": 16,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message"],
              "properties": {
                "code": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 64,
                  "pattern": "^[A-Z0-9_]+$",
                  "description": "Reason code, e.g. STALE_ACCESS, DUPLICATE_HASH"
                },
                "message": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 512,
                  "description": "Human-readable reason (short)."
                },
                "evidence": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Optional structured evidence (timestamps, hash, size, etc.)"
                }
              }
            }
          },

          "risk": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"]
          },

          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },

          "proposed_next": {
            "type": "string",
            "enum": ["review", "archive", "delete", "dedupe", "compress", "ignore"],
            "description": "Recommended next step (NOT executed in this action)."
          },

          "hash": {
            "type": "object",
            "additionalProperties": false,
            "required": ["algorithm", "value"],
            "properties": {
              "algorithm": { "type": "string", "enum": ["sha256", "blake3"] },
              "value": {
                "type": "string",
                "minLength": 16,
                "maxLength": 128,
                "pattern": "^[a-fA-F0-9]+$"
              }
            },
            "description": "Present only if hashing was enabled and file was hashed."
          }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "dir" } }, "required": ["kind"] },
            "then": {
              "properties": {
                "proposed_next": { "enum": ["review", "ignore"] }
              },
              "description": "For dirs we keep it conservative; no delete suggestions."
            }
          }
        ]
      }
    },

    "warnings": {
      "type": "array",
      "maxItems": 2000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 3,
            "maxLength": 64,
            "pattern": "^[A-Z0-9_]+$"
          },
          "message": { "type": "string", "minLength": 3, "maxLength": 512 },
          "path": { "type": "string", "minLength": 1, "maxLength": 1024 }
        }
      }
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleset_id", "ruleset_version", "hashing_enabled"],
      "properties": {
        "ruleset_id": { "type": "string", "minLength": 3, "maxLength": 128 },
        "ruleset_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "hashing_enabled": { "type": "boolean" },
        "notes": { "type": "string", "maxLength": 512 }
      }
    }
  }
}
