{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scan-result.schema.v1",
  "title": "Scan Result Output Schema (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "generated_at", "root", "files", "stats"],
  "properties": {
    "schema_id": { "type": "string", "const": "scan-result" },
    "schema_version": { "type": "string", "const": "v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "root": { "type": "string", "minLength": 1 },

    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size", "mtime"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "size": { "type": "integer", "minimum": 0 },

          "mtime": { "type": "integer", "minimum": 0 },

          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },

    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_files", "total_bytes"],
      "properties": {
        "total_files": { "type": "integer", "minimum": 0 },
        "total_bytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
