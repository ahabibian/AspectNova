{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schema/scan_report.schema.v1.json",
  "title": "Scan Report (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "root", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "root": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_count", "total_bytes", "top_extensions"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "total_bytes": { "type": "integer", "minimum": 0 },
        "top_extensions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ext", "count"],
            "properties": {
              "ext": { "type": "string" },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
