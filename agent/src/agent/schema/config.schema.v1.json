{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agent/schemas/config.schema.v1.json",
  "title": "Config Schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "output", "scan"],
  "properties": {
    "schema_version": { "type": "string", "const": "config_v1" },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir"],
      "properties": {
        "dir": { "type": "string", "minLength": 1, "default": "output" }
      }
    },
    "scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roots"],
      "properties": {
        "roots": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 },
          "minItems": 1
        },
        "include_extensions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "exclude_dirs": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["node_modules", ".git", ".venv", "__pycache__"]
        },
        "hash_max_bytes": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    }
  }
}
